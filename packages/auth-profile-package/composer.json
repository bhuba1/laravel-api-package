{
    "name": "bhuba/auth-profile-package",
    "description": "Token-based auth and profile API for Laravel applications",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/routing": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/cache": "^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Bhuba\\AuthProfilePackage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bhuba\\AuthProfilePackage\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bhuba\\AuthProfilePackage\\AuthProfilePackageServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "scripts": {
        "test": "phpunit",
        "test:docker": "bash scripts/test-docker.sh"
    },
    "suggest": {
        "ext-pdo_sqlite": "Required to run the package test suite locally (or use composer test:docker)"
    }
}
